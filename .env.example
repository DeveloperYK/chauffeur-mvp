# Database
DATABASE_URL=postgres://chauffeur:chauffeur_dev@localhost:5432/chauffeur

# App
NODE_ENV=development
APP_URL=http://localhost:3000

# Driver-link JWT secret (min 32 bytes base64). Generate: openssl rand -base64 32
DRIVER_LINK_SECRET=replace-me-with-a-32-byte-base64-secret-min

# Clock-tick scheduler secret (min 16 chars). The external cron must send this
# as the `x-clock-secret` header on POST /api/clock-tick. Leave blank to
# disable the clock loop (endpoint returns 503). Generate: openssl rand -base64 32
CLOCK_TICK_SECRET=

# Twilio (leave blank in dev to use fake adapter)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Google Sheets (leave blank in dev to use fake adapter)
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Logging
LOG_LEVEL=info

# Auth — set to `true` to bypass the operator login screen and auto-resolve to
# the first active operator (in any environment). SECURITY: leaves the dashboard
# open to anyone with the URL; gate access another way (e.g. platform password
# protection) when enabled. Leave blank/false to require login in production.
AUTH_DISABLED=

# Simulator — set to `true` to expose the operator test simulator (seed data,
# advance the clock, force state transitions) in every environment, including
# production demo deploys. Off by default; the simulator's clock tick always
# uses the in-memory SMS fake, so it never sends real texts.
SIMULATOR_ENABLED=
